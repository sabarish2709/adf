{
	"name": "DataBaseConfig",
	"properties": {
		"activities": [
			{
				"name": "TableCreation",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"preCopyScript": "CREATE TABLE [SalesLT].[Config]\n(\n    Id INT NOT NULL PRIMARY KEY,\n    SourceDirectory NVARCHAR(100) NULL,\n    Query NVARCHAR(100) NULL,\n    TargetTable NVARCHAR(100) NULL,\n    TargetDirectory NVARCHAR(100) NULL\n    \n)",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ConfigData",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "AzureSqlTableConfig",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}